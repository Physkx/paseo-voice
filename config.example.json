{
  "listenHost": "127.0.0.1",
  "listenPort": 8790,
  "openaiModel": "gpt-realtime-2.1",
  "openaiVoice": "marin",
  "openaiBaseUrl": "wss://api.openai.com/v1/realtime",
  "sparkBaseUrl": "https://api.x.ai/v1",
  "sparkModel": "grok-4-1-fast-non-reasoning",
  "allowInsecureTailscaleSpark": false,
  "summariseThresholdChars": 700,
  "logTailEntries": 40,
  "autoReplyPollMs": 1000,
  "proposalTtlMs": 120000,
  "paseoHosts": [
    {
      "id": "wsl",
      "label": "Paseo WSL Host",
      "target": "paseo-wsl.example:6767",
      "default": true,
      "defaultCwd": "~/",
      "defaultProvider": "opencode/gpt-5.6-sol-max"
    },
    {
      "id": "secondary",
      "label": "Secondary Paseo Host",
      "target": "paseo-secondary.example:6767",
      "default": false,
      "defaultCwd": "~/dev",
      "defaultProvider": "codex/gpt-5.4"
    }
  ],
  "secretProvider": "onepassword",
  "onePasswordSecretRefOpenai": "op://Private/OpenAI/credential",
  "onePasswordSecretRefPaseo": "op://Private/Paseo/password",
  "onePasswordSecretRefSpark": "op://Private/xAI/credential",
  "forceMock": false,
  "logLevel": "info"
}
