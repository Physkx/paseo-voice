{
  "name": "paseo-voice",
  "version": "0.1.0",
  "description": "A push-to-talk voice interface for Paseo coding-agent sessions.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm format:check && pnpm lint:agents && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint src test public",
    "lint:agents": "node scripts/lint-agents.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "console": "node dist/console.js"
  },
  "dependencies": {
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "oxlint": "^1.74.0",
    "prettier": "3.9.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
