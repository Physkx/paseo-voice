# Read secrets directly from the process environment for local development.
PASEO_VOICE_SECRET_PROVIDER=environment

# Required only by the exact official OpenAI endpoint. With that default, leave unset for mock mode.
# A credential-free custom endpoint can still run live; PASEO_VOICE_MOCK=true always forces mock.
OPENAI_API_KEY=

# Required for Paseo CLI operations.
PASEO_PASSWORD=

# Optional overrides.
# The API key is sent only to this exact official endpoint. Custom endpoints receive no auth.
# Custom ws:// is accepted only on exact loopback hosts; remote custom endpoints require wss://.
PASEO_VOICE_OPENAI_BASE_URL=wss://api.openai.com/v1/realtime
# Plain HTTP is accepted only for exact loopback hosts; remote endpoints require HTTPS.
PASEO_VOICE_SPARK_BASE_URL=http://127.0.0.1:1234/v1
PASEO_VOICE_SPARK_MODEL=qwen3.5-9b-instruct-nvfp4
