# Select environment-backed resolution for the named apiCredentials in config.json.
PASEO_VOICE_SECRET_PROVIDER=environment

# These names are examples. Each must exactly match one apiCredentials.environmentVariable.
PASEO_VOICE_CREDENTIAL_OPENAI=
PASEO_VOICE_CREDENTIAL_XAI=
PASEO_VOICE_CREDENTIAL_PRIVATE_MODEL=
PASEO_VOICE_CREDENTIAL_SUMMARY=

# Required for Paseo CLI operations when using the environment secret provider.
PASEO_PASSWORD=

# An exact official xAI voice, cleanup, or summarisation route may use the provider-owned Grok CLI
# OAuth session at ~/.grok/auth.json. OAuth is preferred over a named environment credential whose
# configured variable is XAI_API_KEY. Explicit Bitwarden, 1Password, and other named environment
# credentials remain operator overrides. Override the path only when the provider store is elsewhere.
# GROK_AUTH_FILE=~/.grok/auth.json

# Unrelated runtime overrides remain available. Voice, cleanup, summarisation, and model settings
# must be changed in config.json. Legacy OPENAI and SPARK routing overrides are rejected.
PASEO_VOICE_LISTEN_HOST=127.0.0.1
PASEO_VOICE_LISTEN_PORT=8790
PASEO_VOICE_MOCK=false
